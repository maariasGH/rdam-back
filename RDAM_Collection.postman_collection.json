{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-4789-9012-34567890abcd",
		"name": "RDAM Santa Fe API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"description": "Colección completa para testear el flujo de trámites, pagos y certificados del sistema RDAM."
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{ "name": "Login Staff", "request": { "method": "POST", "url": "{{base_url}}/api/auth/login" } },
				{ "name": "Solicitar Código", "request": { "method": "POST", "url": "{{base_url}}/api/auth/ciudadano/solicitar-codigo?email=test@mail.com&recaptcha_token=token_prueba_123" } },
				{ "name": "Verificar Código", "request": { "method": "POST", "url": "{{base_url}}/api/auth/ciudadano/verificar?email=test@mail.com&codigo=123456" } }
			]
		},
		{
			"name": "Trámites",
			"item": [
				{ "name": "Crear Trámite", "request": { "method": "POST", "header": [{"key": "Authorization", "value": "Bearer <TOKEN>"}],"body": {"mode": "raw","raw": "{\n  \"cuil\": \"20461340602\",\n  \"nombre_solicitante\": \"Mariano Arias\",\n  \"email_contacto\": \"mariano@gmail.com\",\n  \"ciudad_solicitante\": \"Santa Fe\",\n  \"fecha_solicitud\": \"2026-03-07\"\n}",
				"options": {
					"raw": {
						"language": "json"
					}
				}}, "url": "{{base_url}}/api/tramites/crear" } },
				{ "name": "Listar Trámites", "request": { "method": "GET", "url": "{{base_url}}/api/tramites" } },
				{ "name": "Mis Solicitudes (Ciudadano)", "request": { "method": "GET", "url": "{{base_url}}/api/tramites/mis-solicitudes?email=test@mail.com" } },
				{ "name": "Actualizar Estado", "request": { "method": "PATCH", "url": "{{base_url}}/api/tramites/1?estado=PAGADA" } }
			]
		},
		{
			"name": "Pagos y Certificados",
			"item": [
				{ "name": "Abrir Pago", "request": { "method": "POST", "url": "{{base_url}}/api/pagos/checkout?tramite_id=1" } },
				{ "name": "Webhook PlusPagos", "request": { "method": "POST","body": {"mode": "raw","raw": "{\n  \"Estado\": \"REALIZADA\",\n  \"TransaccionComercioId\": \"TR-ID-1\",\n  \"TransaccionPlataformaId\": \"PLAT-999999\"\n}",
				"options": {
					"raw": {
						"language": "json"
					}
				}}, "url": "{{base_url}}/api/pagos/webhook" } },
				{ "name": "Ver Certificado (PDF)", "request": { "method": "GET", "url": "{{base_url}}/api/certificados/1" } },
				{ "name": "Emitir Certificado", "request": { "method": "POST", "url": "{{base_url}}/api/certificados/emitir?tramite_id=1&url_s3=http://s3.link&operador_id=1" } }
			]
		},
		{
			"name": "Usuarios",
			"item": [
				{ "name": "Listar Usuarios", "request": { "method": "GET", "url": "{{base_url}}/api/admin/users" } },
				{ "name": "Crear Usuario", "request": { "method": "POST", "url": "{{base_url}}/api/usuarios" } },
				{ "name": "Guardar/Editar Usuario", "request": { "method": "PUT", "url": "{{base_url}}/api/admin/users/1" } }
			]
		}
	],
	"variable": [ { "key": "base_url", "value": "http://localhost:8000" } ]
}